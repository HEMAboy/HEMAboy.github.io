{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "TirePressureOverview",
  "type": "object",
  "required": [
    "briefing",
    "metrics",
    "capabilityModules",
    "marketSnapshots",
    "routeGateways",
    "agentRoles",
    "agentOutputBlocks"
  ],
  "properties": {
    "briefing": {
      "type": "object",
      "required": [
        "conclusion",
        "evidence",
        "risk",
        "visualizationSuggestion",
        "updatedAt",
        "sources",
        "confidence",
        "publishStatus",
        "lastReviewedAt",
        "dataMethod"
      ],
      "properties": {
        "conclusion": { "type": "string" },
        "evidence": { "type": "string" },
        "risk": { "type": "string" },
        "visualizationSuggestion": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date" },
        "sources": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["id", "sourceType", "sourceTitle", "sourceUrl", "quotedAt", "note"],
            "properties": {
              "id": { "type": "string" },
              "sourceType": {
                "enum": [
                  "official",
                  "government-relay",
                  "industry-association",
                  "marketplace",
                  "commodity-tracker",
                  "research"
                ]
              },
              "sourceTitle": { "type": "string" },
              "sourceUrl": { "type": "string", "format": "uri" },
              "quotedAt": { "type": "string", "format": "date" },
              "note": { "type": "string" }
            },
            "additionalProperties": false
          }
        },
        "confidence": { "enum": ["high", "medium", "low"] },
        "publishStatus": {
          "enum": ["draft", "reviewed", "published", "needs_review"]
        },
        "lastReviewedAt": { "type": "string", "format": "date" },
        "dataMethod": { "type": "string" }
      },
      "additionalProperties": false
    },
    "metrics": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "label",
          "value",
          "note",
          "sources",
          "confidence",
          "publishStatus",
          "lastReviewedAt",
          "dataMethod"
        ],
        "properties": {
          "id": { "type": "string" },
          "label": { "type": "string" },
          "value": { "type": "string" },
          "note": { "type": "string" },
          "sources": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["id", "sourceType", "sourceTitle", "sourceUrl", "quotedAt", "note"],
              "properties": {
                "id": { "type": "string" },
                "sourceType": {
                  "enum": [
                    "official",
                    "government-relay",
                    "industry-association",
                    "marketplace",
                    "commodity-tracker",
                    "research"
                  ]
                },
                "sourceTitle": { "type": "string" },
                "sourceUrl": { "type": "string", "format": "uri" },
                "quotedAt": { "type": "string", "format": "date" },
                "note": { "type": "string" }
              },
              "additionalProperties": false
            }
          },
          "confidence": { "enum": ["high", "medium", "low"] },
          "publishStatus": {
            "enum": ["draft", "reviewed", "published", "needs_review"]
          },
          "lastReviewedAt": { "type": "string", "format": "date" },
          "dataMethod": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "capabilityModules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "title",
          "machineSet",
          "fitProducts",
          "advantage",
          "marketLink",
          "sources",
          "confidence",
          "publishStatus",
          "lastReviewedAt",
          "dataMethod"
        ],
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string" },
          "machineSet": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
          "fitProducts": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
          "advantage": { "type": "string" },
          "marketLink": { "type": "string" },
          "sources": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["id", "sourceType", "sourceTitle", "sourceUrl", "quotedAt", "note"],
              "properties": {
                "id": { "type": "string" },
                "sourceType": {
                  "enum": [
                    "official",
                    "government-relay",
                    "industry-association",
                    "marketplace",
                    "commodity-tracker",
                    "research"
                  ]
                },
                "sourceTitle": { "type": "string" },
                "sourceUrl": { "type": "string", "format": "uri" },
                "quotedAt": { "type": "string", "format": "date" },
                "note": { "type": "string" }
              },
              "additionalProperties": false
            }
          },
          "confidence": { "enum": ["high", "medium", "low"] },
          "publishStatus": {
            "enum": ["draft", "reviewed", "published", "needs_review"]
          },
          "lastReviewedAt": { "type": "string", "format": "date" },
          "dataMethod": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "marketSnapshots": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "title",
          "region",
          "timeframe",
          "trend",
          "summary",
          "implication",
          "sources",
          "confidence",
          "publishStatus",
          "lastReviewedAt",
          "dataMethod"
        ],
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string" },
          "region": { "type": "string" },
          "timeframe": { "type": "string" },
          "trend": { "enum": ["up", "mixed", "watch"] },
          "summary": { "type": "string" },
          "implication": { "type": "string" },
          "sources": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["id", "sourceType", "sourceTitle", "sourceUrl", "quotedAt", "note"],
              "properties": {
                "id": { "type": "string" },
                "sourceType": {
                  "enum": [
                    "official",
                    "government-relay",
                    "industry-association",
                    "marketplace",
                    "commodity-tracker",
                    "research"
                  ]
                },
                "sourceTitle": { "type": "string" },
                "sourceUrl": { "type": "string", "format": "uri" },
                "quotedAt": { "type": "string", "format": "date" },
                "note": { "type": "string" }
              },
              "additionalProperties": false
            }
          },
          "confidence": { "enum": ["high", "medium", "low"] },
          "publishStatus": {
            "enum": ["draft", "reviewed", "published", "needs_review"]
          },
          "lastReviewedAt": { "type": "string", "format": "date" },
          "dataMethod": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "routeGateways": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "title", "href", "description", "highlights"],
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string" },
          "href": { "type": "string" },
          "description": { "type": "string" },
          "highlights": { "type": "array", "items": { "type": "string" }, "minItems": 1 }
        },
        "additionalProperties": false
      }
    },
    "agentRoles": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "name", "responsibility", "needsWeb", "sequence"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "responsibility": { "type": "string" },
          "needsWeb": { "type": "boolean" },
          "sequence": { "type": "integer" }
        },
        "additionalProperties": false
      }
    },
    "agentOutputBlocks": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    }
  },
  "additionalProperties": false
}
