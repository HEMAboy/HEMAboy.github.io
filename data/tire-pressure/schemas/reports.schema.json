{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "TirePressureReports",
  "type": "object",
  "required": ["pageMeta", "reportTags", "reports"],
  "properties": {
    "pageMeta": {
      "type": "object",
      "required": [
        "conclusion",
        "evidence",
        "risk",
        "visualizationSuggestion",
        "updatedAt",
        "sources",
        "confidence",
        "publishStatus",
        "lastReviewedAt",
        "dataMethod"
      ],
      "properties": {
        "conclusion": { "type": "string" },
        "evidence": { "type": "string" },
        "risk": { "type": "string" },
        "visualizationSuggestion": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date" },
        "sources": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["id", "sourceType", "sourceTitle", "sourceUrl", "quotedAt", "note"],
            "properties": {
              "id": { "type": "string" },
              "sourceType": {
                "enum": [
                  "official",
                  "government-relay",
                  "industry-association",
                  "marketplace",
                  "commodity-tracker",
                  "research"
                ]
              },
              "sourceTitle": { "type": "string" },
              "sourceUrl": { "type": "string", "format": "uri" },
              "quotedAt": { "type": "string", "format": "date" },
              "note": { "type": "string" }
            },
            "additionalProperties": false
          }
        },
        "confidence": { "enum": ["high", "medium", "low"] },
        "publishStatus": { "enum": ["draft", "reviewed", "published", "needs_review"] },
        "lastReviewedAt": { "type": "string", "format": "date" },
        "dataMethod": { "type": "string" }
      },
      "additionalProperties": false
    },
    "reportTags": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "reports": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "category",
          "title",
          "summary",
          "region",
          "evidenceLevel",
          "sourceSummary",
          "recommendedAction",
          "tags",
          "agentOutput",
          "sources",
          "confidence",
          "publishStatus",
          "lastReviewedAt",
          "dataMethod"
        ],
        "properties": {
          "id": { "type": "string" },
          "category": { "enum": ["国内市场", "国际市场", "外贸与认证", "原材料与成本", "竞争格局"] },
          "title": { "type": "string" },
          "summary": { "type": "string" },
          "region": { "type": "string" },
          "evidenceLevel": { "enum": ["结构化占位", "重点补证", "待二次验证"] },
          "sourceSummary": { "type": "string" },
          "recommendedAction": { "type": "string" },
          "tags": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
          "agentOutput": {
            "type": "object",
            "required": [
              "conclusion",
              "evidence",
              "risk",
              "visualizationSuggestion",
              "updatedAt",
              "sources",
              "confidence",
              "publishStatus",
              "lastReviewedAt",
              "dataMethod"
            ],
            "properties": {
              "conclusion": { "type": "string" },
              "evidence": { "type": "string" },
              "risk": { "type": "string" },
              "visualizationSuggestion": { "type": "string" },
              "updatedAt": { "type": "string", "format": "date" },
              "sources": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "object",
                  "required": ["id", "sourceType", "sourceTitle", "sourceUrl", "quotedAt", "note"],
                  "properties": {
                    "id": { "type": "string" },
                    "sourceType": {
                      "enum": [
                        "official",
                        "government-relay",
                        "industry-association",
                        "marketplace",
                        "commodity-tracker",
                        "research"
                      ]
                    },
                    "sourceTitle": { "type": "string" },
                    "sourceUrl": { "type": "string", "format": "uri" },
                    "quotedAt": { "type": "string", "format": "date" },
                    "note": { "type": "string" }
                  },
                  "additionalProperties": false
                }
              },
              "confidence": { "enum": ["high", "medium", "low"] },
              "publishStatus": {
                "enum": ["draft", "reviewed", "published", "needs_review"]
              },
              "lastReviewedAt": { "type": "string", "format": "date" },
              "dataMethod": { "type": "string" }
            },
            "additionalProperties": false
          },
          "sources": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["id", "sourceType", "sourceTitle", "sourceUrl", "quotedAt", "note"],
              "properties": {
                "id": { "type": "string" },
                "sourceType": {
                  "enum": [
                    "official",
                    "government-relay",
                    "industry-association",
                    "marketplace",
                    "commodity-tracker",
                    "research"
                  ]
                },
                "sourceTitle": { "type": "string" },
                "sourceUrl": { "type": "string", "format": "uri" },
                "quotedAt": { "type": "string", "format": "date" },
                "note": { "type": "string" }
              },
              "additionalProperties": false
            }
          },
          "confidence": { "enum": ["high", "medium", "low"] },
          "publishStatus": { "enum": ["draft", "reviewed", "published", "needs_review"] },
          "lastReviewedAt": { "type": "string", "format": "date" },
          "dataMethod": { "type": "string" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
