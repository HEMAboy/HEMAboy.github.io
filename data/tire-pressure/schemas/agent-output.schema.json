{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AgentOutputPayload",
  "type": "object",
  "required": [
    "conclusion",
    "evidence",
    "risk",
    "visualizationSuggestion",
    "updatedAt",
    "sources",
    "confidence",
    "publishStatus",
    "lastReviewedAt",
    "dataMethod"
  ],
  "properties": {
    "conclusion": { "type": "string", "minLength": 1 },
    "evidence": { "type": "string", "minLength": 1 },
    "risk": { "type": "string", "minLength": 1 },
    "visualizationSuggestion": { "type": "string", "minLength": 1 },
    "updatedAt": { "type": "string", "format": "date" },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "sourceType", "sourceTitle", "sourceUrl", "quotedAt", "note"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "sourceType": {
            "enum": [
              "official",
              "government-relay",
              "industry-association",
              "marketplace",
              "commodity-tracker",
              "research"
            ]
          },
          "sourceTitle": { "type": "string", "minLength": 1 },
          "sourceUrl": { "type": "string", "format": "uri" },
          "quotedAt": { "type": "string", "format": "date" },
          "note": { "type": "string", "minLength": 1 }
        },
        "additionalProperties": false
      }
    },
    "confidence": { "enum": ["high", "medium", "low"] },
    "publishStatus": {
      "enum": ["draft", "reviewed", "published", "needs_review"]
    },
    "lastReviewedAt": { "type": "string", "format": "date" },
    "dataMethod": { "type": "string", "minLength": 1 }
  },
  "additionalProperties": false
}
